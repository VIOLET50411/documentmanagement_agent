.page { display:flex; flex-direction:column; height:100vh; background:#f8fafc; }
.status { padding:24rpx; color:#475569; font-size:24rpx; }
.messages { flex:1; padding:24rpx; }
.message { margin-bottom:16rpx; padding:20rpx; border-radius:16rpx; background:#e2e8f0; color:#0f172a; }
.message.user { background:#dbeafe; }
.message.assistant { background:#ffffff; }
.composer { display:flex; gap:16rpx; padding:24rpx; background:#fff; box-shadow: 0 -12rpx 30rpx rgba(15,23,42,0.06); }
input { flex:1; border:1px solid #cbd5e1; border-radius:12rpx; padding:16rpx; background:#fff; }
button { background:#0f172a; color:#fff; border-radius:12rpx; }
