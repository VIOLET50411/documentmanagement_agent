.page { min-height: 100vh; padding: 48rpx 32rpx; background: linear-gradient(180deg, #e2e8f0 0%, #f8fafc 100%); }
.hero { margin-top: 80rpx; }
.title { font-size: 48rpx; font-weight: 700; color: #0f172a; }
.subtitle { margin-top: 20rpx; font-size: 28rpx; line-height: 1.6; color: #475569; }
.form-card { margin-top: 48rpx; padding: 32rpx; border-radius: 24rpx; background: #ffffff; box-shadow: 0 20rpx 50rpx rgba(15, 23, 42, 0.08); }
.label { margin-bottom: 12rpx; font-size: 24rpx; color: #334155; font-weight: 600; }
.field { margin-bottom: 24rpx; padding: 20rpx 24rpx; border: 2rpx solid #cbd5e1; border-radius: 16rpx; background: #fff; }
.button-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.half { flex: 1; }
.submit { background: #0f172a; color: #fff; border-radius: 16rpx; }
.ghost { background: #e2e8f0; color: #0f172a; border-radius: 16rpx; }
.hint { margin-bottom: 24rpx; color: #64748b; font-size: 22rpx; line-height: 1.6; }
.hint.success { color: #0f766e; }
.error { margin-top: 20rpx; color: #b91c1c; font-size: 24rpx; }
