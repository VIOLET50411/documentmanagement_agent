<view class="page">
  <view class="status-card">
    <view class="section-title compact">微信通知绑定</view>
    <view class="meta">配置状态：{{bootstrapStatus}}</view>
    <view class="meta">模板 ID：{{wechatTemplateId || '未下发'}}</view>
    <view class="meta">订阅状态：{{wechatSubscribeStatus}}</view>
    <view wx:if="{{wechatLastBindMessage}}" class="meta">{{wechatLastBindMessage}}</view>
    <view class="meta">{{wechatSubscriptionAdvice}}</view>
    <view wx:if="{{pushSummary}}" class="meta">
      当前终端：{{pushSummary.current_token_status || 'not_provided'}} | 已登记设备：{{pushSummary.total || 0}}
    </view>
    <view wx:if="{{pushSummary}}" class="meta">
      活跃设备：{{pushSummary.active || 0}} | 非活跃设备：{{pushSummary.inactive || 0}}
    </view>
    <view wx:if="{{pushSummary && pushSummary.current_device}}" class="meta">
      当前设备名：{{pushSummary.current_device.device_name || '未命名'}} | 平台：{{pushSummary.current_device.platform || 'unknown'}}
    </view>
    <view class="hint">一次性订阅消息会被消费，关键通知发送前会再次申请授权并刷新当前微信设备绑定。</view>
    <view class="actions actions-compact">
      <button class="primary" size="mini" loading="{{wechatBinding}}" bindtap="bindWechatSubscription">授权并绑定微信通知</button>
      <button class="business" size="mini" loading="{{businessNotificationPreparing}}" bindtap="prepareBusinessNotifications">接收文档处理通知</button>
      <button class="ghost" size="mini" loading="{{deviceRegistering}}" bindtap="registerCurrentDevice">登记当前终端</button>
      <button class="ghost" size="mini" loading="{{deviceHeartbeatLoading}}" bindtap="heartbeatCurrentDevice">刷新终端状态</button>
      <button class="ghost" size="mini" loading="{{notificationSending}}" bindtap="sendTestNotification">发送测试通知</button>
    </view>
  </view>

  <view class="status-card" wx:if="{{pushEvents.length}}">
    <view class="section-title compact">最近推送事件</view>
    <block wx:for="{{pushEvents}}" wx:key="timestamp">
      <view class="event-item">
        <view class="event-title">{{item.title || '通知事件'}}</view>
        <view class="meta">状态：{{item.status || 'unknown'}} | 发送：{{item.delivery && item.delivery.sent || 0}} | 失败：{{item.delivery && item.delivery.failed || 0}}</view>
      </view>
    </block>
  </view>

  <view class="toolbar">
    <input class="search" value="{{query}}" bindinput="onQueryInput" placeholder="搜索制度、合同、流程" />
    <button class="btn" size="mini" loading="{{searchLoading}}" bindtap="searchDocuments">搜索</button>
  </view>

  <view class="actions">
    <button class="ghost" size="mini" bindtap="refreshDocumentsWithBusinessSubscription">刷新文档</button>
    <button class="ghost" size="mini" bindtap="goChat">进入对话</button>
    <button class="ghost danger" size="mini" bindtap="logout">退出</button>
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view class="section-title">文档列表</view>
  <view wx:if="{{loading}}" class="muted">正在加载文档...</view>
  <block wx:for="{{documents}}" wx:key="id">
    <view class="card">
      <view class="card-title">{{item.title}}</view>
      <view class="meta">状态：{{item.status}} | 部门：{{item.department || 'public'}}</view>
      <view class="meta">大小：{{item.file_size || 0}} 字节</view>
    </view>
  </block>

  <view class="section-title">搜索结果</view>
  <block wx:for="{{searchResults}}" wx:key="chunk_id">
    <view class="card result">
      <view class="card-title">{{item.document_title}}</view>
      <view class="meta">章节：{{item.section_title || '未标注'}} | 分数：{{item.score}}</view>
      <view class="snippet">{{item.snippet}}</view>
    </view>
  </block>
</view>
