.page { min-height: 100vh; padding: 24rpx; background: #f8fafc; }
.status-card { margin-bottom: 20rpx; padding: 20rpx 24rpx; border-radius: 18rpx; background: #ffffff; box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.05); }
.hint { margin-top: 12rpx; color: #64748b; font-size: 22rpx; line-height: 1.6; }
.toolbar { display: flex; gap: 16rpx; align-items: center; }
.search { flex: 1; padding: 18rpx 22rpx; border-radius: 14rpx; border: 2rpx solid #cbd5e1; background: #fff; }
.btn { background: #0f172a; color: #fff; border-radius: 14rpx; }
.primary { background: #0f766e; color: #fff; border-radius: 14rpx; }
.business { background: #1d4ed8; color: #fff; border-radius: 14rpx; }
.actions { display: flex; gap: 16rpx; margin: 20rpx 0 12rpx; }
.actions-compact { margin: 16rpx 0 0; }
.ghost { background: #e2e8f0; color: #0f172a; border-radius: 14rpx; }
.ghost.danger { color: #991b1b; }
.section-title { margin: 28rpx 0 16rpx; font-size: 30rpx; font-weight: 600; color: #0f172a; }
.section-title.compact { margin: 0 0 12rpx; font-size: 28rpx; }
.card { margin-bottom: 16rpx; padding: 24rpx; border-radius: 18rpx; background: #fff; box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.05); }
.card-title { font-size: 28rpx; font-weight: 600; color: #0f172a; }
.event-item { padding: 16rpx 0; border-top: 1rpx solid #e2e8f0; }
.event-item:first-child { border-top: none; }
.event-title { font-size: 26rpx; font-weight: 600; color: #0f172a; }
.meta { margin-top: 8rpx; color: #64748b; font-size: 24rpx; }
.snippet { margin-top: 12rpx; color: #334155; font-size: 24rpx; line-height: 1.6; }
.error { margin-top: 12rpx; color: #b91c1c; font-size: 24rpx; }
.muted { color: #64748b; font-size: 24rpx; }
