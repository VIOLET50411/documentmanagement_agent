# ============================================================
# DocMind Agent - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME=DocMind Agent
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000
BACKEND_PORT=8000
FRONTEND_PORT=5173
FLOWER_PORT=5555
APP_AUTO_CREATE_TABLES=true
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_SIZE_MB=100
BOOTSTRAP_DEMO_ADMIN_ENABLED=true
BOOTSTRAP_DEMO_ADMIN_USERNAME=admin_demo
BOOTSTRAP_DEMO_ADMIN_PASSWORD=Password123
BOOTSTRAP_DEMO_ADMIN_EMAIL=admin_demo@docmind.local
BOOTSTRAP_DEMO_ADMIN_TENANT_ID=default
BOOTSTRAP_DEMO_ADMIN_DEPARTMENT=Platform

# --- JWT Authentication ---
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_ALLOW_PUBLIC_REGISTRATION=false
AUTH_STATELESS_JWT_CONTEXT=true
AUTH_ALLOWLIST_DOMAINS=

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=docmind
POSTGRES_PASSWORD=docmind_password
POSTGRES_DB=docmind_db
POSTGRES_POOL_SIZE=80
POSTGRES_MAX_OVERFLOW=80
POSTGRES_POOL_TIMEOUT_SECONDS=30

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Milvus ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=docmind_vectors

# --- Elasticsearch ---
ES_HOST=localhost
ES_PORT=9200
ES_INDEX=docmind_documents

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# --- MinIO (S3-Compatible Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=docmind-documents
MINIO_SECURE=false

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- AI / LLM APIs (Fill in your keys later) ---
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_API_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:1.5b
LLM_CANARY_PERCENT=10
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=
EMBEDDING_CANARY_PERCENT=10
RERANKER_PROVIDER=local
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_API_KEY=
RERANKER_API_BASE_URL=
VECTOR_LOCAL_FALLBACK_ENABLED=false
HYBRID_VECTOR_ENABLED=false
RERANKER_CANARY_PERCENT=10
OCR_PROVIDER=paddleocr

# --- Semantic Cache ---
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95
SEMANTIC_CACHE_TTL_SECONDS=300

# --- Security ---
PII_MASKING_ENABLED=true
GUARDRAILS_ENABLED=true
GUARDRAILS_SIDECAR_URL=http://localhost:8090
GUARDRAILS_FAIL_CLOSED=true
WATERMARK_ENABLED=true
RUNTIME_MAINTENANCE_ALERT_REPAIRED_TTL_THRESHOLD=50
RUNTIME_MAINTENANCE_ALERT_EMPTY_REPLAY_THRESHOLD=100
RUNTIME_STAGE_TIMEOUT_SECONDS=90
CLAMAV_ENABLED=false
CLAMAV_FAIL_CLOSED=true
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
SECURITY_POLICY_PROFILE=financial

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
RAGAS_API_BASE_URL=http://localhost:8091
RAGAS_API_KEY=
RAGAS_REQUIRE_REAL_MODE=true

# --- CI Gate ---
CI_GATE_MIN_RUNTIME_SAMPLES=1
CI_GATE_MAX_FALLBACK_RATE=0.8
CI_GATE_MAX_DENY_RATE=0.8
CI_GATE_REQUIRE_REAL_RAGAS=true
CI_GATE_MIN_FAITHFULNESS=0.85
CI_GATE_MIN_ANSWER_RELEVANCY=0.8
CI_GATE_MIN_CONTEXT_PRECISION=0.8
CI_GATE_MIN_CONTEXT_RECALL=0.8
