# ============================================================
# DocMind Agent - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Application ---
APP_NAME=DocMind Agent
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000
BACKEND_PORT=8000
FRONTEND_PORT=5173
FLOWER_PORT=5555
APP_AUTO_CREATE_TABLES=true
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_SIZE_MB=100
BOOTSTRAP_DEMO_ADMIN_ENABLED=true
BOOTSTRAP_DEMO_ADMIN_USERNAME=admin_demo
BOOTSTRAP_DEMO_ADMIN_PASSWORD=Password123
BOOTSTRAP_DEMO_ADMIN_EMAIL=admin_demo@docmind.local
BOOTSTRAP_DEMO_ADMIN_TENANT_ID=default
BOOTSTRAP_DEMO_ADMIN_DEPARTMENT=Platform

# --- JWT Authentication ---
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_ALLOW_PUBLIC_REGISTRATION=false
AUTH_STATELESS_JWT_CONTEXT=true
AUTH_ALLOWLIST_DOMAINS=
AUTH_BLOCKLIST_DOMAINS=mailinator.com,10minutemail.com,guerrillamail.com,temp-mail.org
AUTH_MOBILE_OAUTH_ENABLED=true
AUTH_MOBILE_OAUTH_CLIENTS=docmind-capacitor,docmind-miniapp
AUTH_MOBILE_OAUTH_REDIRECT_URIS=docmind://auth/callback,https://servicewechat.com/docmind/callback
AUTH_MOBILE_AUTHORIZATION_CODE_EXPIRE_MINUTES=5

# --- Push Notifications ---
PUSH_NOTIFICATIONS_ENABLED=true
PUSH_NOTIFICATION_PROVIDER=multi
PUSH_NOTIFICATION_FAIL_CLOSED=false
PUSH_AUTO_DEACTIVATE_INVALID_TOKENS=true

# FCM:
# 1. 推荐: 使用 service account 文件
#    PUSH_FCM_SERVICE_ACCOUNT_FILE=/run/secrets/docmind/firebase-service-account.json
# 2. 备选: 使用 access token + project id
#    PUSH_FCM_ACCESS_TOKEN=
#    PUSH_FCM_PROJECT_ID=your-firebase-project-id
# 3. 旧版兼容: server key
#    PUSH_FCM_SERVER_KEY=
PUSH_FCM_ENDPOINT=https://fcm.googleapis.com/fcm/send
PUSH_FCM_SERVER_KEY=
PUSH_FCM_ACCESS_TOKEN=
PUSH_FCM_PROJECT_ID=
PUSH_FCM_SERVICE_ACCOUNT_FILE=

# 微信小程序订阅消息:
# 二选一提供 access token 来源
# 1. 直接填 access token
# 2. 使用 appid/appsecret 自动换取 access token
PUSH_WECHAT_ACCESS_TOKEN=
PUSH_WECHAT_APP_ID=
PUSH_WECHAT_APP_SECRET=
PUSH_WECHAT_TEMPLATE_ID=
PUSH_WECHAT_PAGE=pages/docs/index
PUSH_WECHAT_MINIPROGRAM_STATE=developer
PUSH_WECHAT_LANG=zh_CN

# 可选 webhook 推送
PUSH_NOTIFICATION_WEBHOOK_URL=

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=docmind
POSTGRES_PASSWORD=docmind_password
POSTGRES_DB=docmind_db
POSTGRES_POOL_SIZE=80
POSTGRES_MAX_OVERFLOW=80
POSTGRES_POOL_TIMEOUT_SECONDS=30

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Milvus ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=docmind_vectors

# --- Elasticsearch ---
ES_HOST=localhost
ES_PORT=9200
ES_INDEX=docmind_documents

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# --- MinIO (S3-Compatible Object Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=docmind-documents
MINIO_SECURE=false

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- AI / LLM APIs (Fill in your keys later) ---
LLM_PROVIDER=ollama
LLM_API_KEY=
LLM_API_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:1.5b
LLM_CANARY_PERCENT=10
LLM_ENTERPRISE_ENABLED=false
LLM_ENTERPRISE_API_BASE_URL=http://localhost:11434/v1
LLM_ENTERPRISE_MODEL_NAME=
LLM_ENTERPRISE_API_KEY=
LLM_ENTERPRISE_KEYWORDS=制度,审批,流程,合规,预算,采购,合同,报销,风控,审计,人事,绩效,会议纪要,管理办法
LLM_ENTERPRISE_FORCE_TENANTS=
LLM_ENTERPRISE_CANARY_PERCENT=0
LLM_ENTERPRISE_CANARY_SEED=docmind-enterprise-llm
LLM_ENTERPRISE_CORPUS_MIN_CHARS=80
LLM_TRAINING_PROVIDER=script
LLM_TRAINING_BASE_MODEL=qwen2.5:7b
LLM_TRAINING_ARTIFACTS_SUBDIR=model_training
LLM_TRAINING_MIN_TRAIN_RECORDS=20
LLM_TRAINING_AUTO_ACTIVATE=true
LLM_TRAINING_EXECUTOR_API_BASE_URL=
LLM_TRAINING_EXECUTOR_API_KEY=
LLM_TRAINING_EXECUTOR_TIMEOUT_SECONDS=1800
LLM_TRAINING_EXECUTOR_POLL_INTERVAL_SECONDS=5
# 可选：本地脚本训练执行器。命令支持占位符：
# {job_id} {tenant_id} {dataset_name} {base_model} {target_model_name}
# {artifact_dir} {export_dir} {manifest_path} {request_json_path}
# Docker 开发环境示例：
# LLM_TRAINING_PROVIDER=script
# LLM_TRAINING_EXECUTOR_SCRIPT_COMMAND=python /app/scripts/run_lora_sft.py --request-json {request_json_path} --allow-plan-fallback
# 若 base_model 使用 Ollama 名称（如 qwen2.5:7b），可额外指定 HF 模型：
# DOCMIND_TRAINING_HF_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
# Windows 本地示例：
# LLM_TRAINING_EXECUTOR_SCRIPT_COMMAND=py -3 backend/scripts/run_lora_sft.py --request-json {request_json_path} --allow-plan-fallback
LLM_TRAINING_EXECUTOR_SCRIPT_COMMAND=
LLM_TRAINING_EXECUTOR_SCRIPT_WORKDIR=
LLM_TRAINING_PUBLISH_ENABLED=false
# 可选：真实发布训练产物。命令支持占位符：
# {model_name} {target_model_name} {base_model} {artifact_dir} {adapter_dir} {modelfile_path} {serving_base_url} {serving_model_name}
# Linux 容器示例（需容器内已安装 ollama CLI 且 OLLAMA_HOST 可达）：
# LLM_TRAINING_PUBLISH_COMMAND=ollama create {target_model_name} -f {modelfile_path}
LLM_TRAINING_PUBLISH_COMMAND=
LLM_TRAINING_PUBLISH_WORKDIR=
LLM_TRAINING_DEPLOY_VERIFY_ENABLED=true
LLM_TRAINING_DEPLOY_HEALTH_PATH=
LLM_TRAINING_DEPLOY_VERIFY_TIMEOUT_SECONDS=20
LLM_TRAINING_DEPLOY_FAIL_ROLLBACK=true
# 示例导出参数：
# POST /api/v1/admin/llm/domain-corpus/export?doc_limit=200&chunk_limit=4000&max_access_level=3&deduplicate=true&train_ratio=0.9
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=
EMBEDDING_CANARY_PERCENT=10
RERANKER_PROVIDER=local
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_API_KEY=
RERANKER_API_BASE_URL=
VECTOR_LOCAL_FALLBACK_ENABLED=false
HYBRID_VECTOR_ENABLED=false
RERANKER_CANARY_PERCENT=10
OCR_PROVIDER=paddleocr

# --- Semantic Cache ---
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95
SEMANTIC_CACHE_TTL_SECONDS=300

# --- Security ---
PII_MASKING_ENABLED=true
GUARDRAILS_ENABLED=true
GUARDRAILS_SIDECAR_URL=http://localhost:8090
GUARDRAILS_FAIL_CLOSED=true
WATERMARK_ENABLED=true
RUNTIME_MAINTENANCE_ALERT_REPAIRED_TTL_THRESHOLD=50
RUNTIME_MAINTENANCE_ALERT_EMPTY_REPLAY_THRESHOLD=100
RUNTIME_STAGE_TIMEOUT_SECONDS=600
CLAMAV_ENABLED=false
CLAMAV_FAIL_CLOSED=true
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
SECURITY_POLICY_PROFILE=financial

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
RAGAS_API_BASE_URL=http://localhost:8091
RAGAS_API_KEY=
RAGAS_LLM_BASE_URL=http://localhost:11434/v1
# 默认使用 qwen2.5:1.5b 作为评估 judge；若机器资源允许，可改成 qwen2.5:7b 提升评估稳定性。
RAGAS_LLM_MODEL=qwen2.5:1.5b
RAGAS_EMBEDDING_BASE_URL=http://localhost:11434/v1
RAGAS_EMBEDDING_MODEL=nomic-embed-text
RAGAS_REQUIRE_REAL_MODE=true
RAGAS_MAX_WORKERS=2

# --- CI Gate ---
CI_GATE_MIN_RUNTIME_SAMPLES=1
CI_GATE_MAX_FALLBACK_RATE=0.8
CI_GATE_MAX_DENY_RATE=0.8
CI_GATE_REQUIRE_REAL_RAGAS=true
CI_GATE_MIN_FAITHFULNESS=0.85
CI_GATE_MIN_ANSWER_RELEVANCY=0.8
CI_GATE_MIN_CONTEXT_PRECISION=0.8
CI_GATE_MIN_CONTEXT_RECALL=0.8
CI_GATE_MIN_FAITHFULNESS_RAGAS_OLLAMA=0.8
CI_GATE_MIN_ANSWER_RELEVANCY_RAGAS_OLLAMA=0.4
CI_GATE_MIN_CONTEXT_PRECISION_RAGAS_OLLAMA=0.8
CI_GATE_MIN_CONTEXT_RECALL_RAGAS_OLLAMA=0.7
CI_GATE_EVAL_SAMPLE_LIMIT=5
CI_GATE_MIN_EVAL_DATASET_SIZE=5
CI_GATE_MIN_EVAL_UNIQUE_DOCS=2
CI_GATE_MIN_EVAL_DIFFICULTY_BUCKETS=2

